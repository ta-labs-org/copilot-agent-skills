@model IEnumerable<OracleWebApp.Models.Product>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Products";
    int currentPage  = ViewBag.Page;
    int totalPages   = ViewBag.TotalPages;
    string search    = ViewBag.Search as string ?? "";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Products</h2>
        <a href="@Url.Action("Create")" class="btn btn-success">
            + New Product
        </a>
    </div>

    <!-- Search form -->
    <form method="get" action="@Url.Action("Index")" class="row g-2 mb-4">
        <div class="col-auto">
            <input type="text" name="search" value="@search"
                   class="form-control" placeholder="Search by name or description..." />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
        @if (!string.IsNullOrEmpty(search))
        {
            <div class="col-auto">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Clear</a>
            </div>
        }
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No products found.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.ProductId</td>
                        <td>@product.ProductName</td>
                        <td>@product.Price.ToString("C")</td>
                        <td>@product.Stock</td>
                        <td>@product.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a href="@Url.Action("Details", new { id = product.ProductId })" class="btn btn-sm btn-info text-white">Details</a>
                            <a href="@Url.Action("Edit",    new { id = product.ProductId })" class="btn btn-sm btn-warning">Edit</a>
                            <a href="@Url.Action("Delete",  new { id = product.ProductId })" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Pager -->
        @if (totalPages > 1)
        {
            <nav aria-label="Products pager">
                <ul class="pagination">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { search, page = currentPage - 1 })">
                            &laquo; Prev
                        </a>
                    </li>
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { search, page = p })">@p</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { search, page = currentPage + 1 })">
                            Next &raquo;
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
